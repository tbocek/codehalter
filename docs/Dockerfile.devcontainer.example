# .devcontainer/Dockerfile
# Built from golang:1-bookworm because codehalter needs a recent Go and
# bookworm's golang-go package is too old. The base is still Debian.
FROM golang:1-trixie

ARG USERNAME=dev
ARG UID=1000
ARG GID=1000

# Toolchain — trim what you don't use; add cargo, openjdk-17, python3, etc.
# as your project needs them. just/make are picked up by codehalter's
# task-runner discovery automatically; nodejs+npm covers package.json.
# firefox-esr powers web_search/web_read; codehalter launches it with
# -headless so no X11 forwarding is needed.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git sudo \
        just make \
        nodejs npm \
        firefox-esr \
    && rm -rf /var/lib/apt/lists/*

# Non-root user matching host UID/GID so files written into the bind-mounted
# workspace stay owned by your host user, not root.
RUN groupadd --gid ${GID} ${USERNAME} \
    && useradd --uid ${UID} --gid ${GID} -m -s /bin/bash ${USERNAME} \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} \
    && install -d -o ${UID} -g ${GID} /home/${USERNAME}/.config

# Install codehalter into a system path so Zed's `command` lookup is stable
# across container rebuilds. GOPROXY=direct fetches straight from GitHub so
# you always get the current main; proxy.golang.org's @latest resolution can
# lag behind by hours.
ENV GOBIN=/usr/local/bin
RUN GOPROXY=direct go install github.com/tbocek/codehalter@latest

# gopls powers the go_symbols / go_references tools (LSP workspace/symbol and
# textDocument/references). codehalter spawns `gopls serve` lazily on first
# use, so the daemon costs nothing until the model asks for it.
RUN go install golang.org/x/tools/gopls@latest

USER ${USERNAME}
